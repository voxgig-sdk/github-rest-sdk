                reqd: false
                type: "`$STRING`"
              }
              {
                example: "open"
                kind: "query"
                name: "state"
                orig: "state"
                reqd: false
                type: "`$STRING`"
              }
            ]
          }
          method: "GET"
          orig: "/repos/{owner}/{repo}/issues"
          parts: [
            "repos"
            "{owner}"
            "{repo}"
            "issues"
          ]
          select: {
            exist: [
              "direction"
              "label"
              "owner"
              "page"
              "per_page"
              "repo"
              "sort"
              "state"
            ]
