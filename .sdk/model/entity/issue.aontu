                name: "repo"
                orig: "repo"
                reqd: true
                type: "`$STRING`"
              }
            ]
          }
          method: "GET"
          orig: "/repos/{owner}/{repo}/issues/{issue_number}"
          parts: [
            "repos"
            "{owner}"
            "{repo}"
            "issues"
            "{id}"
          ]
          rename: {
            param: {
              issue_number: "id"
            }
          }
          select: {
            exist: [
              "id"
              "owner"
              "repo"
            ]
          }
          transform: {
            req: "`reqdata`"
            res: "`body`"
          }
