              }
            ]
          }
          method: "POST"
          orig: "/repos/{owner}/{repo}/issues"
          parts: [
            "repos"
            "{owner}"
            "{repo}"
            "issues"
          ]
          select: {
            exist: [
              "owner"
              "repo"
            ]
          }
          transform: {
            req: "`reqdata`"
            res: "`body`"
          }
        }
      ]
    }
    list: {
      name: "list"
      points: [
        {
          args: {
            params: [
