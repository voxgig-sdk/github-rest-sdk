# BasicBranchFlow

main: kit: flow: BasicBranchFlow:
{
  entity: "branch",
  kind: "basic",
  name: "BasicBranchFlow",
  step: [
    {
      match: {
        owner: "owner01",
        repo: "repo01"
      }

      op: "list",
      valid: [
        {
          apply: "ItemExists",
          def: {
            ref: "branch_ref01"
          }
        }
      ]
    }
  ],
  "key$": "BasicBranchFlow"
}