# BasicCommitFlow

main: kit: flow: BasicCommitFlow:
{
  entity: "commit",
  kind: "basic",
  name: "BasicCommitFlow",
  step: [
    {
      match: {
        owner: "owner01",
        repo: "repo01"
      }

      op: "list",
      valid: [
        {
          apply: "ItemExists",
          def: {
            ref: "commit_ref01"
          }
        }
      ]
    }
  ],
  "key$": "BasicCommitFlow"
}